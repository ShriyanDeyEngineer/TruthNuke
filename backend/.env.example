# TruthNuke Backend Environment Configuration
# Copy this file to .env and fill in your values

# LLM Configuration (Required)
# API key for the LLM service (OpenAI, Anthropic, etc.)
LLM_API_KEY=your-llm-api-key-here

# LLM model to use (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# RAG Pipeline Configuration
# Number of top results to retrieve from search providers (default: 5)
TOP_K=5

# Input Validation
# Maximum allowed input text length in characters (default: 50000)
MAX_INPUT_LENGTH=50000

# Trust Score Configuration
# Comma-separated weights for trust score components:
# Source_Credibility, Evidence_Strength, Language_Neutrality, Cross_Source_Agreement
# Must sum to 1.0 (default: 0.3,0.3,0.2,0.2)
TRUST_SCORE_WEIGHTS=0.3,0.3,0.2,0.2

# CORS Configuration
# Allowed origin for frontend requests (default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000
